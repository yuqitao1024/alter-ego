# Lark assistant
ALTER_EGO_LARK_APP_ID=
ALTER_EGO_LARK_APP_SECRET=
ALTER_EGO_LARK_DOMAIN=https://open.feishu.cn
ALTER_EGO_LARK_ALLOW_USERS=
ALTER_EGO_LARK_ALLOW_GROUPS=
ALTER_EGO_LARK_REQUIRE_MENTION=true
ALTER_EGO_LARK_CALLBACK_LISTEN_ADDR=:8080
ALTER_EGO_LARK_CALLBACK_PUBLIC_URL=

# LLM provider
ALTER_EGO_LLM_PROVIDER=dashscope
ALTER_EGO_LLM_API_KEY=
ALTER_EGO_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ALTER_EGO_LLM_MODEL=glm-5.1

# Task subsystem
ALTER_EGO_TASK_CONFIG_ROOT=/opt/alterego/config
ALTER_EGO_TASK_DB_PATH=/var/lib/alterego/tasks.db

# Remote task execution
# Machine YAML under /opt/alterego/config owns app_server_socket and app_server_bootstrap.
