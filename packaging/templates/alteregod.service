[Unit]
Description=Alter Ego daemon
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/alterego
EnvironmentFile=/etc/alterego/alterego.env
ExecStart=/opt/alterego/bin/alterego
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
